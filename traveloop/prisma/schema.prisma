generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  bio             String?
  location        String?
  currency        String    @default("USD")
  theme           String    @default("dark")
  role            String    @default("USER")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  trips           Trip[]
  collaborations  Collaborator[]
  notifications   Notification[]
  savedDestinations SavedDestination[]
  reviews         Review[]
  journals        Journal[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Trip {
  id           String       @id @default(cuid())
  title        String
  description  String?
  coverImage   String?
  startDate    DateTime?
  endDate      DateTime?
  status       String       @default("PLANNING")
  isPublic     Boolean      @default(false)
  budget       Float?
  currency     String       @default("USD")
  totalCost    Float?       @default(0)
  likes        Int          @default(0)
  views        Int          @default(0)
  slug         String?      @unique
  userId       String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops        Stop[]
  budgetItems  BudgetItem[]
  packingItems PackingItem[]
  collaborators Collaborator[]
  notifications Notification[]
  sharedTrips  SharedTrip[]
  journals     Journal[]
  reviews      Review[]

  @@index([userId])
  @@index([isPublic])
  @@index([status])
  @@map("trips")
}

model Stop {
  id          String     @id @default(cuid())
  tripId      String
  cityName    String
  country     String?
  lat         Float?
  lng         Float?
  arrivalDate  DateTime?
  departureDate DateTime?
  order       Int        @default(0)
  notes       String?
  coverImage  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  trip        Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities  Activity[]

  @@index([tripId])
  @@map("stops")
}

model Activity {
  id           String         @id @default(cuid())
  stopId       String
  title        String
  description  String?
  category     String         @default("SIGHTSEEING")
  startTime    DateTime?
  endTime      DateTime?
  cost         Float?         @default(0)
  currency     String?        @default("USD")
  address      String?
  lat          Float?
  lng          Float?
  image        String?
  bookingUrl   String?
  rating       Float?
  isBooked     Boolean        @default(false)
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  stop         Stop           @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@index([stopId])
  @@map("activities")
}

model BudgetItem {
  id          String       @id @default(cuid())
  tripId      String
  category    String         @default("OTHER")
  title       String
  amount      Float
  currency    String       @default("USD")
  date        DateTime?
  isPaid      Boolean      @default(false)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  trip        Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("budget_items")
}

model PackingItem {
  id          String   @id @default(cuid())
  tripId      String
  name        String
  category    String   @default("General")
  isPacked    Boolean  @default(false)
  quantity    Int      @default(1)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("packing_items")
}

model Collaborator {
  id        String          @id @default(cuid())
  tripId    String
  userId    String
  role      String           @default("VIEWER")
  joinedAt  DateTime        @default(now())

  trip      Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
  @@map("collaborators")
}

model SharedTrip {
  id        String   @id @default(cuid())
  tripId    String
  shareCode String   @unique @default(cuid())
  expiresAt DateTime?
  createdAt DateTime @default(now())

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("shared_trips")
}

model Journal {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  title     String
  content   String
  mood      String?
  date      DateTime @default(now())
  images    String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([userId])
  @@map("journals")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  tripId    String?
  type      String
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip?            @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model SavedDestination {
  id          String   @id @default(cuid())
  userId      String
  cityName    String
  country     String?
  image       String?
  lat         Float?
  lng         Float?
  savedAt     DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cityName])
  @@index([userId])
  @@map("saved_destinations")
}

model Review {
  id          String   @id @default(cuid())
  tripId      String
  userId      String
  rating      Float
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@map("reviews")
}

// Removed enums for sqlite compatibility
